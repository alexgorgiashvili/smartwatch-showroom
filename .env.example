APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=redis
CACHE_PREFIX=smartwatch_cache
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

OPENAI_API_KEY=sk-
OPENAI_ORG_ID=org-
OPENAI_MODEL=gpt-4.1-mini
OPENAI_JUDGE_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_JUDGE_PROVIDER=openai

# New Chatbot Architecture
CHATBOT_SUPERVISOR_ENABLED=true
CHATBOT_SUPERVISOR_MODEL=gpt-4o-mini

# Parallel Execution
CHATBOT_PARALLEL_EXECUTION_ENABLED=true
CHATBOT_PARALLEL_TASK_TIMEOUT=10

# Caching
CHATBOT_CACHE_ENABLED=true
CHATBOT_EMBEDDING_CACHE_TTL=3600
CHATBOT_SEMANTIC_CACHE_TTL=1800
CHATBOT_SEMANTIC_CACHE_THRESHOLD=0.95
CHATBOT_RESPONSE_CACHE_TTL=600

# Circuit Breaker
CHATBOT_CIRCUIT_BREAKER_ENABLED=true
CHATBOT_CIRCUIT_BREAKER_THRESHOLD=5
CHATBOT_CIRCUIT_BREAKER_RESET_TIMEOUT=300

# Conditional Reflection
CHATBOT_REFLECTION_ENABLED=true
CHATBOT_REFLECTION_MAX_RETRIES=3
CHATBOT_REFLECTION_CONFIDENCE_THRESHOLD=0.7
CHATBOT_REFLECTION_CRITIQUE_MODEL=gpt-4o-mini

# Streaming
CHATBOT_STREAMING_ENABLED=false

# Memory
CHATBOT_MEMORY_SESSION_WINDOW=4
CHATBOT_MEMORY_SUMMARIZATION_ENABLED=true
# Optional (only if you later switch LLM_JUDGE_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# AI Mode: 'professional' (default) or 'sarcastic' (for fun/testing)
AI_MODE=professional

PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=products

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Chatbot test suite schedule (used by app/Console/Kernel.php unless customized in code)
CHATBOT_TEST_SCHEDULE=03:00

WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:admin@localhost

APIFY_API_TOKEN=
APIFY_ACTOR_ID=apify/web-scraper
APIFY_BASE_URL=https://api.apify.com/v2
APIFY_TIMEOUT=180
APIFY_USE_PROXY=true
APIFY_RETRY_WITH_RESIDENTIAL=true
APIFY_PROXY_COUNTRY=
APIFY_RESPECT_ROBOTS=false
APIFY_USE_TEMPLATE_PAGE_FUNCTION=false
APIFY_INPUT_TEMPLATE_JSON=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

#========================================
# Security Configuration
#========================================
# Webhook signature verification timeout (in seconds, default: 300 = 5 minutes)
WEBHOOK_SIGNATURE_TIMEOUT=300

# Webhook rate limiting (max messages per minute per customer)
WEBHOOK_RATE_LIMIT=100

# Maximum message content length (in characters)
MAX_MESSAGE_LENGTH=5000

# Rate limiting for different endpoints (requests per minute)
WEBHOOK_RECEPTION_RATE_LIMIT=1000
MESSAGE_SEND_RATE_LIMIT=30
AI_SUGGESTION_RATE_LIMIT=10
SEARCH_RATE_LIMIT=60
GET_REQUESTS_RATE_LIMIT=200
POST_REQUESTS_RATE_LIMIT=100

# Data encryption
ENCRYPT_MESSAGE_CONTENT=false

# Logging
LOG_WEBHOOK_PAYLOADS=false
LOG_SENSITIVE_DATA=false

# Data retention policies (in days)
MESSAGE_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=180
WEBHOOK_LOG_RETENTION_DAYS=30
